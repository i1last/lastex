% Инициализация глобального окружения и движка форматирования
\begin{python}
import math
import cmath
import os
import sys
import re

def _check_and_import_safe():
    """
    Функция проверяет наличие конфликтующей папки 'code' 
    перед тем, как позволить коду работать дальше.
    """
    current_dir = os.getcwd()
    bad_folder = os.path.join(current_dir, 'code')
    
    # 1. Сначала проверяем физическое наличие папки
    if os.path.isdir(bad_folder):
        error_msg = (
            f"\n"
            f"! ОШИБКА СТРУКТУРЫ ПРОЕКТА:\n"
            f"! Обнаружена папка '{bad_folder}'.\n"
            f"! Имя 'code' ЗАПРЕЩЕНО, так как оно\n"
            f"! занято системной библиотекой Python.\n"
            f"! РЕШЕНИЕ:\n"
            f"! 1. Переименуйте папку 'code/' в 'scripts/'.\n"
            f"! 2. В .tex замените 'from code.calc' на 'from scripts.calc'.\n"
        )
        
        error_msg += "\n"
        
        # Печатаем жирно в лог и прерываем выполнение
        print(error_msg, file=sys.stderr)

# Запускаем проверку немедленно
_check_and_import_safe()

def _format_val(val, fmt: str = "", is_math: bool = False) -> str:
    r"""
    Форматирование числового значения на основе синтаксиса [a].[b][c][+]
    
    Синтаксис формата: [a].[b][c][+]
        [a] (опционально): Целое число. Принудительно делит значение на 10^a.
        [b] (опционально, после точки): Целое число. Точность округления.
            Если b >= 0: количество знаков после запятой.
            Если b < 0: округление до десятков, сотен и т.д.
        [c] (опционально): 'e' — вывод в виде \cdot 10^{exp}
        [+] (опционально): Всегда показывать знак (+ для ≥0, - для <0)
    
    Примеры:
        val = 5465
        '+3.2'     -> +5.47
        '3.2+'     -> +5.47
        '+.2e'     -> +5.47 \cdot 10^{3}
        '-3.0+'    -> +5     (для val=0.005465)
        val = -2.34
        '+'        -> -2.34
    """
    if val is None:
        return "---"
    
    # Нечисловые типы возвращаются как есть
    if not isinstance(val, (int, float, complex)):
        res = str(val)
        return f"${res}$" if is_math else res

    # Поддержка модификатора '+' в конце
    show_sign = False
    clean_fmt = fmt.strip()
    
    if clean_fmt.startswith('+'):
        show_sign = True
        clean_fmt = clean_fmt[1:].strip()

    a, b, c = None, None, ''
    
    # Парсинг строки модификаторов с помощью регулярного выражения
    if clean_fmt:
        # Паттерн: 
        # 1. ([-+]?\d+)?      - Опциональное целое число [a]
        # 2. (?:\.([-+]?\d*))? - Опциональная точка и целое число [b]
        # 3. ([e])?          - Опциональный символ 'e' или '' [c]
        match = re.match(r'^([-+]?\d+)?(?:\.([-+]?\d*))?([e])?$', clean_fmt)
        if match:
            a_str, b_str, c_str = match.groups()
            if a_str is not None: 
                a = int(a_str)
            if b_str is not None and b_str != '': 
                b = int(b_str)
            if c_str is not None: 
                c = c_str
        else:
            return "??? Formatting Invalid"
            
    def _fmt_single(v: float) -> str:
        """Внутренняя функция форматирования действительного числа."""
        # 1. Определение мантиссы и степени
        if a is not None:
            exp = a
            mantissa = v / (10 ** exp)
        elif c == 'e':
            if v == 0:
                exp = 0
                mantissa = 0.0
            else:
                exp = math.floor(math.log10(abs(v)))
                mantissa = v / (10 ** exp)
        else:
            exp = 0
            mantissa = v

        # 2. Округление (параметр b)
        if b is not None:
            mantissa = round(mantissa, b)
            if b > 0:
                m_str = f"{mantissa:.{b}f}"
            else:
                m_str = str(int(mantissa))
        else:
            # Если b не задано, используем стандартное строковое представление.
            # Встроенный str() в Python может выдать '1e-05' для малых чисел.
            m_str = str(mantissa)
            if 'e' in m_str and c != 'e':
                base, p_exp = m_str.split('e')
                return f"{base} \\cdot 10^{{{int(p_exp)}}}"

        # 3. Добавление знака, если требуется модификатор '+'
        if show_sign:
            if mantissa >= 0:   # важно: проверяем mantissa, а не исходное v
                sign = '+'
            else:
                sign = '-'
                mantissa = abs(mantissa)  # убираем минус из строки
                # переформатируем строку без знака
                if b is not None and b > 0:
                    m_str = f"{mantissa:.{b}f}"
                elif b is not None and b <= 0:
                    m_str = str(int(mantissa))
                else:
                    m_str = str(mantissa)
            final_str = f"{sign}{m_str}"
        else:
            final_str = m_str

        # 4. Формирование степени (если 'e')
        if c == 'e':
            return f"{final_str} \\cdot 10^{{{exp}}}"
        else:
            return final_str

    # Обработка комплексных чисел
    if isinstance(val, complex):
        re_part = _fmt_single(val.real, forced_sign)   # знак нужен только для реальной части
        im_part = _fmt_single(val.imag)
        sign = "+" if val.imag >= 0 else "-"
        im_part = im_part.replace("-", "")
        res = f"{re_part} {sign} j{im_part}"
    else:
        res = _fmt_single(val, forced_sign)        
        
    return f"${res}$" if is_math else res

def _pv(expr: str, fmt: str, is_math: bool) -> str:
    """
    Вычисление Python-выражения и форматирование единичного значения.
    """
    try:
        val = eval(expr)
        return _format_val(val, fmt, is_math)
    except Exception as e:
        print(f'! {e}')
        return f"???"

def _pt(exprs_str: str, fmts_str: str, start_idx: int, end_idx: int, is_math: bool) -> str:
    """
    Генерация LaTeX-кода для строк таблицы из массивов Python.
    
    Параметры:
        exprs_str: Строка с именами массивов через запятую (напр., 'I_arr, U_arr').
        fmts_str: Форматы для каждого столбца через ','.
        start_idx: Начальный индекс (в формате LaTeX, 1-based).
        end_idx: Конечный индекс (-1 для вывода до конца).
        is_math: Обертывать ли ячейки в $...$.
    """
    try:
        arrays = eval(f"({exprs_str},)")
    except Exception as e:
        return f"???"
        
    fmts =[f.strip() for f in fmts_str.split(',')] if fmts_str else[]
    
    # Преобразование индексов: LaTeX (1-based) -> Python (0-based)
    max_len = max((len(arr) for arr in arrays if hasattr(arr, '__len__')), default=0)
    start = max(0, start_idx - 1)
    end = max_len if end_idx == -1 else min(end_idx, max_len)
    
    rows =[]
    for i in range(start, end):
        row_data =[]
        for col_idx, arr in enumerate(arrays):
            val = arr[i] if hasattr(arr, '__len__') and i < len(arr) else None
            # Применение индивидуального формата столбца или формата первого столбца по умолчанию
            fmt = fmts[col_idx] if col_idx < len(fmts) else (fmts[0] if fmts else "")
            row_data.append(_format_val(val, fmt, is_math))
        
        # Объединение ячеек в строку таблицы
        rows.append(" & ".join(row_data))
        
    # Объединение строк таблицы
    return " \\\\ ".join(rows)
\end{python}

% Макросы пользовательского интерфейса
